APP_NAME=Pinakes
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://pinakes.dev-vp.sagres.dom
APP_LOCALE=it
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=it_IT

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mariadb
DB_HOST=pinakes_mariadb_dev
DB_PORT=3306
DB_DATABASE=pinakes
DB_USERNAME=root
DB_PASSWORD=password

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.dev-vp.sagres.dom

CACHE_STORE=redis
CACHE_PREFIX=pinakes_

REDIS_CLIENT=predis
REDIS_HOST=pinakes_redis_dev
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS=dev@sagresgestioni.it
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
VITE_APP_URL="${APP_URL}"

SANCTUM_STATEFUL_DOMAINS=pinakes.dev-vp.sagres.dom,localhost,localhost:5173
CORS_ALLOWED_ORIGINS=https://pinakes.dev-vp.sagres.dom

HORIZON_PREFIX=pinakes_horizon:

SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://pinakes_meilisearch_dev:7700
MEILISEARCH_KEY=pinakes-dev-meili
