{
    "name": "vincenzopirozzideveloper/pinakes",
    "type": "project",
    "description": "Personal wiki and digital garden, DDD + Hexagonal Architecture",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "laravel/framework": "^12.0",
        "laravel/horizon": "^5.0",
        "laravel/sanctum": "^4.0",
        "laravel/scout": "^10.0",
        "laravel/tinker": "^2.9",
        "league/commonmark": "^2.4",
        "predis/predis": "^2.0",
        "spatie/browsershot": "^4.0",
        "spatie/commonmark-shiki-highlighter": "^2.3",
        "spatie/laravel-data": "^4.0",
        "spatie/laravel-feed": "^4.0",
        "spatie/laravel-sitemap": "^7.0",
        "symfony/uid": "^7.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.13",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "phpstan/phpstan": "^1.11",
        "qossmic/deptrac-shim": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "test": "pest",
        "lint": "pint",
        "stan": "phpstan analyse"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
